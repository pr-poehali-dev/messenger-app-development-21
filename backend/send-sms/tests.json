{
  "tests": [
    {
      "name": "Send SMS to valid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "send", "phone": "79991234567"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true, "demo": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reject invalid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "send", "phone": "123"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify wrong code",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify", "phone": "79991234567", "code": "000000"},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    }
  ]
}